# Shopify Admin API
# Create a custom app in Shopify Admin > Settings > Apps and sales channels > Develop apps
# Required scopes: read_products, read_orders, read_content
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxx

# Optional: Judge.me reviews integration
# Get your API token from Judge.me dashboard > Settings > API
JUDGEME_API_TOKEN=

# Google Ads API
# See: https://developers.google.com/google-ads/api/docs/first-call/overview
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# TikTok Ads API
# Get from TikTok Business Center > Assets > Developer Portal
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Meta (Facebook + Instagram) Graph API
# Get a Page Access Token from Meta Business Suite or Graph API Explorer
# Required permissions: pages_show_list, pages_read_engagement, pages_read_user_content,
#   pages_manage_posts, instagram_basic, instagram_manage_insights, instagram_content_publish
META_ACCESS_TOKEN=
META_PAGE_ID=
META_INSTAGRAM_ID=
# User-level token for Ads Library API (visit fb.com/ads/library and accept Terms while logged in as this user)
META_USER_ACCESS_TOKEN=

# Meta Ads Library — competitor research and creative inspiration
# META_AD_SEARCH_TERMS: comma-separated keywords to search in the Ads Library
#   e.g. "gift shop philippines,flower delivery manila,hamper delivery ph"
META_AD_SEARCH_TERMS=
# META_COMPETITOR_PAGE_IDS: comma-separated Facebook Page IDs of competitor brands
#   Find a page's ID via: https://graph.facebook.com/v21.0/{page_username}?fields=id&access_token={token}
META_COMPETITOR_PAGE_IDS=1525480224187725,
# META_AD_COUNTRY: ISO 3166-1 alpha-2 country code for ad targeting filter (default: PH)
META_AD_COUNTRY=PH

# Google Workspace (Drive, Calendar, Gmail, Business Profile reviews)
# Run: npm run google:setup  to generate GOOGLE_REFRESH_TOKEN via OAuth2 browser flow
# Create OAuth2 credentials at: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Enable these APIs: Drive API, Calendar API, Gmail API, My Business Account Management API
# Add redirect URI: http://localhost:3999/oauth2callback
# Under "OAuth consent screen" → add your Google account as a test user
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional: specific calendar to use (defaults to "primary")
GOOGLE_CALENDAR_ID=
# Optional: default Google Drive folder for uploads
GOOGLE_DRIVE_FOLDER_ID=
# Optional: default email recipient for sent reports
GOOGLE_MAIL_DEFAULT_TO=
# Optional: pre-fill after running npm run google:reviews -- --setup-info
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_api_key_here

# Google Gemini API — for AI image generation (/gen_image command)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
